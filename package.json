{
  "name": "texdict",
  "displayName": "TeXDict",
  "description": "Search a LaTeX command by its concept name and insert it at the cursor.",
  "version": "0.0.3",
  "publisher": "yutosasaki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ys-math/texdict.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "texdict.search",
        "title": "TeXDict: Search LaTeX Dictionary"
      }
    ],
    "keybindings": [
      {
        "command": "texdict.search",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorLangId == latex"
      }
    ],
    "languages": [
      {
        "id": "latex",
        "aliases": [
          "LaTeX"
        ],
        "extensions": [
          ".tex"
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0"
  }
}
