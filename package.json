{
  "name": "texdict",
  "displayName": "TeXDict",
  "description": "Search a LaTeX command by its concept name and insert it at the cursor.",
  "version": "0.0.9",
  "publisher": "yutosasaki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ys-math/texdict.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "texdict.search",
        "title": "TeXDict: Search LaTeX Dictionary"
      },
      {
        "command": "texdict.saveTemplate",
        "title": "TeXDict: Save Selection as Template"
      }
    ],
    "keybindings": [
      {
        "command": "texdict.search",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorLangId == latex"
      }
    ],
    "languages": [
      {
        "id": "latex",
        "aliases": [
          "LaTeX"
        ],
        "extensions": [
          ".tex"
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "texdict",
          "title": "TeXDict",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "texdict": [
        {
          "id": "texdict.palette",
          "name": "Symbols",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node scripts/copy-katex.js",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "katex": "^0.16.47"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0"
  }
}
